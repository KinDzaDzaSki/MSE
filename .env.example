# Copy this file to `.env` and fill in your values (do NOT commit .env).
# On Render, DATABASE_URL is injected automatically by the render.yaml blueprint.

# PostgreSQL connection string (Render Postgres add-on provides this).
# Local example:
# DATABASE_URL=postgresql://user:password@localhost:5432/mse

# Optional: server port (Render sets this automatically).
# PORT=3000
