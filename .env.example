# Copy this file to `.env` and fill in your values (do NOT commit .env).
# On Render AND Railway, DATABASE_URL is injected automatically when you
# attach a PostgreSQL plugin/database — you usually don't need to set it manually.

# PostgreSQL connection string (Railway/Postgres add-on provides this).
# Local example:
# DATABASE_URL=postgresql://user:password@localhost:5432/mse

# Optional: server port (hosts set this automatically).
# PORT=3000
